# =============================================================================
# LogSentinel Configuration
# Copy this file to .env and update values as needed
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://LogSentinel:LogSentinel@localhost:5432/LogSentinel
DATABASE_URL_SYNC=postgresql://LogSentinel:LogSentinel@localhost:5432/LogSentinel
POSTGRES_USER=LogSentinel
POSTGRES_PASSWORD=LogSentinel
POSTGRES_DB=LogSentinel

# --- Application ---
APP_NAME=LogSentinel
APP_VERSION=1.0.0
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# --- Anomaly Detection ---
ANOMALY_ERROR_RATE_THRESHOLD=0.15
ANOMALY_LATENCY_THRESHOLD_MS=2000.0
ANOMALY_WINDOW_SIZE=100
ANOMALY_WINDOW_TIME_SECONDS=300
ANOMALY_COOLDOWN_SECONDS=60

# --- Remediation ---
REMEDIATION_ENABLED=false
REMEDIATION_MODE=mock
AWS_REGION=us-east-1
AWS_LAMBDA_FUNCTION_NAME=LogSentinel-remediation
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
REMEDIATION_WEBHOOK_URL=

# --- Prometheus ---
PROMETHEUS_ENABLED=true

# --- Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
